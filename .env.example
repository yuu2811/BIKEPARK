# ===========================================
# BIKEPARK 環境変数
# ===========================================
# このファイルをコピーして .env.local を作成してください:
#   cp .env.example .env.local
#
# 各値の取得方法は README.md の「セットアップ手順」を参照

# -------------------------------------------
# Supabase
# -------------------------------------------
# Supabase Dashboard > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# -------------------------------------------
# Google Maps
# -------------------------------------------
# Google Cloud Console > 認証情報 から取得
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Cloud Console > Google Maps Platform > Maps Management で作成
NEXT_PUBLIC_GOOGLE_MAP_ID=your_google_map_id
